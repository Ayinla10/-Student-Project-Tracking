# Neon PostgreSQL connection string (SSL required)
# Get this from your Neon project dashboard -> Connection Details
DATABASE_URL=postgres://<user>:<password>@<host>/<dbname>?sslmode=require

# Session secret - use a long random string in production
SESSION_SECRET=change-this-to-a-long-random-secret

# App port
PORT=3000

# Default admin credentials (used only by the seed script on first run)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

NODE_ENV=development
