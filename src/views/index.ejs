<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Project Tracker</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="topbar">
    <h1>📘 Student Project Tracker</h1>
    <div class="user-info"><a href="/admin/login" style="color:#fff;">Admin Login</a></div>
  </div>

  <div class="container">
    <div class="card">
      <h2 style="margin-top:0;color:var(--blue-900);">Submit / Update Your Project Status</h2>
      <p class="hint">Enter your roll number first. If you've registered before, your name and supervisor will load automatically and you'll only need to update your status.</p>

      <form id="studentForm" autocomplete="off">
        <div class="form-group">
          <label for="rollNumber">Roll Number *</label>
          <input type="text" id="rollNumber" name="rollNumber" required placeholder="e.g. CSC/2021/045" />
        </div>

        <div id="lookupHint" class="hint"></div>

        <div class="form-group" id="fullNameGroup">
          <label for="fullName">Full Name *</label>
          <input type="text" id="fullName" name="fullName" placeholder="Your full name" />
        </div>

        <div class="form-group" id="supervisorGroup">
          <label for="supervisor">Assigned Supervisor *</label>
          <input type="text" id="supervisor" name="supervisor" placeholder="Supervisor's name" />
        </div>

        <div class="form-group">
          <label for="status">Current Project Status *</label>
          <select id="status" name="status" required>
            <option value="">Select status</option>
            <option>Proposal</option>
            <option>Chapter 1</option>
            <option>Chapter 2</option>
            <option>Chapter 3</option>
            <option>Chapter 4</option>
            <option>Chapter 5</option>
            <option>Completed</option>
          </select>
        </div>

        <button type="submit" class="btn" id="submitBtn">
          <span class="spinner"></span>
          <span class="btn-label">Submit</span>
        </button>
      </form>
    </div>
  </div>

  <div id="toast" class="toast"></div>

  <script src="/js/student.js"></script>
</body>
</html>
